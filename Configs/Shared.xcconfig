// 公共编译配置模板 — 下一步绑定 Xcode 工程时引用
// 真实 Team ID / Bundle ID 请放 Local.xcconfig（已 gitignore）

PRODUCT_NAME = ProxyClient
SWIFT_VERSION = 5.0
IPHONEOS_DEPLOYMENT_TARGET = 17.0
TARGETED_DEVICE_FAMILY = 1,2
ENABLE_USER_SCRIPT_SANDBOXING = YES

// 占位：在 Local.xcconfig 中覆盖
// DEVELOPMENT_TEAM = YOUR_TEAM_ID
// PRODUCT_BUNDLE_IDENTIFIER = com.example.proxyclient
// APP_GROUP_ID = group.com.example.proxyclient
